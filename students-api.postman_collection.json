            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/enrollments/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"APROBADO\"\n}"
            }
          }
        },
        {
          "name": "DELETE - Eliminar inscripción",

{
  "info": {
    "name": "Students API - CRUD Completo",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8787"
    }
  ],
  "item": [
    {
      "name": "Students",
      "item": [
        {
          "name": "POST - Crear estudiante",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/students",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ana Torres\",\n  \"email\": \"ana@puce.edu.ec\"\n}"
            }
          }
        },
        {
          "name": "GET - Listar todos los estudiantes",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/students"
          }
        },
        {
          "name": "GET - Obtener estudiante por ID",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/api/students/1"
          }
        },
        {
          "name": "PUT - Actualizar estudiante",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{base_url}}/api/students/1",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ana Torres Ruiz\",\n  \"email\": \"ana.torres@puce.edu.ec\"\n}"
            }
          }
        },
        {
          "name": "DELETE - Eliminar estudiante",
          "request": {
            "method": "DELETE",
            "url": "{{base_url}}/api/students/1"
          }
        }
      ]
    },
